# ===========================
# MCP Todo - Environment Variables
# ===========================

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DBNAME=claude_todo

# Redis
REDIS_URI=redis://redis:6379/0
REDIS_MCP_URI=redis://redis:6379/1

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
REFRESH_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database Auth
MONGO_USER=todoadmin
MONGO_PASSWORD=changeme
REDIS_PASSWORD=changeme

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Initial Admin User (for init-admin CLI command)
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=

# Public URLs
# - BASE_URL:     backend's public origin (MCP OAuth base, release URLs)
# - FRONTEND_URL: SPA's public origin. Used for CORS, Google OAuth
#                 redirect_uri, WebAuthn (RP ID + expected_origin), and
#                 the agent WebSocket Origin allowlist (CSWSH defense).
# In the standard single-origin deployment these two are the same.
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# WebAuthn display name shown in the browser's Passkey prompt.
# The RP ID and expected_origin are derived from FRONTEND_URL.
WEBAUTHN_RP_NAME=MCP Todo

# Login rate limit (per email, failed attempts only)
# Defaults are tuned for an internal team — tighten in production.
LOGIN_MAX_ATTEMPTS=20
LOGIN_LOCKOUT_SECONDS=300
