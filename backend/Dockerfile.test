# Test image — includes dev dependencies (pytest, fakeredis, etc.)
# Runs in mock mode by default (mongomock-motor + fakeredis, no external DB).
#
# Build:
#   docker compose -f backend/docker-compose.test.yml build test
#
# Run (mock mode):
#   docker compose -f backend/docker-compose.test.yml run --rm test
#
# Run (real mode — requires mongo-test + redis-test services):
#   docker compose -f backend/docker-compose.test.yml run --rm test-real
#
# Run a specific test file:
#   docker compose -f backend/docker-compose.test.yml run --rm test \
#       uv run pytest tests/test_auth.py -v

# ── Stage 1: Build tantivy-py with Lindera (Rust) ──────────
# Reuse the same commit and patch as the production Dockerfile so the
# build is cached when nothing changes.
FROM python:3.12-slim AS tantivy-builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl build-essential git pkg-config libssl-dev && \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y && \
    rm -rf /var/lib/apt/lists/*
ENV PATH="/root/.cargo/bin:$PATH"

RUN pip install --no-cache-dir maturin

WORKDIR /build
ARG TANTIVY_PY_COMMIT=bbaa8c0c91529ca215fd82d864dac27cae3b269f
RUN git clone https://github.com/quickwit-oss/tantivy-py.git . && \
    git checkout ${TANTIVY_PY_COMMIT}
COPY patches/tantivy-py-lindera.patch /tmp/
RUN git apply /tmp/tantivy-py-lindera.patch
RUN maturin build --release --strip -o /dist

# ── Stage 2: Test runner ────────────────────────────────────
FROM python:3.12-slim

WORKDIR /app

# Install uv (pin same range as production Dockerfile)
RUN pip install --no-cache-dir "uv>=0.6,<0.7"

# Install production + dev dependencies (pytest, fakeredis, mongomock-motor, ...)
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen

# Install the tantivy wheel built in Stage 1
COPY --from=tantivy-builder /dist/*.whl /tmp/
RUN uv pip install --python /app/.venv/bin/python --no-cache /tmp/*.whl

# Copy application source and test suite
COPY app/ ./app/
COPY tests/ ./tests/

ENV PATH="/app/.venv/bin:$PATH" \
    TZ=Asia/Tokyo

# Default: mock mode (no external DB), skip tests that require:
#   - pip-audit network access          → tests/test_audit.py
#   - Docker daemon (testcontainers)    → test_mcp_session_continuity.py
#                                         test_agent_bus_realredis.py
CMD ["uv", "run", "pytest", "--tb=short", "-q", \
     "--ignore=tests/test_audit.py", \
     "--ignore=tests/integration/test_mcp_session_continuity.py", \
     "--ignore=tests/integration/test_agent_bus_realredis.py"]
