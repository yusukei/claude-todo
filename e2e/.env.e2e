# E2E 専用の固定環境変数。
#
# これらは本番秘密ではない — リポジトリに公開コミットして良い。
# 本番 .env を絶対に参照しないよう、E2E compose は --env-file 経由でこのファイルだけを読む。
#
# 機密が必要な値 (Google OAuth など) は E2E スコープでは未使用。

# JWT 鍵 (E2E 専用、長さ要件 ≥32 を満たす)
SECRET_KEY=e2e_only_secret_key_do_not_use_in_prod_xxxxxxxxxxxxxxxxxxxxxx
REFRESH_SECRET_KEY=e2e_only_refresh_secret_do_not_use_in_prod_xxxxxxxxxxxxxxxxx

# Mongo / Redis 認証 (E2E は tmpfs 上の使い捨て)
MONGO_USER=e2eadmin
MONGO_PASSWORD=e2epass
REDIS_PASSWORD=e2eredispass

# 自動 admin 作成 (backend lifespan が読む)
INIT_ADMIN_EMAIL=admin@e2e.local
INIT_ADMIN_PASSWORD=E2eAdmin!Pass2026

# フロントエンドが見る公開 URL (Traefik 経由)
# runner からは traefik:80、ホストからは localhost:8081 でアクセス可能
FRONTEND_URL=http://traefik
BASE_URL=http://traefik

# E2E スタックは単純化のため WEB_CONCURRENCY=1
WEB_CONCURRENCY=1
